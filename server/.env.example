# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# SQLite database file (created automatically)
DB_PATH=./data/app.db

# LLM (Gemini or OpenAI) — used for pre-visit and post-visit summaries
# Supported values: gemini, openai. If not set, system auto-detects based on configured API keys.
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Email (SMTP — works with Mailgun, SendGrid SMTP relay, Gmail app password, etc.)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM="Clinic Care <no-reply@clinic.example.com>"

# Google Calendar OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/calendar/google/callback

# Background jobs
REMINDER_JOB_CRON=*/5 * * * *
EMAIL_RETRY_JOB_CRON=*/2 * * * *
SLOT_HOLD_TTL_MINUTES=5
